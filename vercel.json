{
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "/blog.html"
    },
    {
      "source": "/projects/:path*",
      "destination": "/projects.html"
    },
    {
      "source": "/photos",
      "destination": "/photos.html"
    },
    {
      "source": "/photos/:path*",
      "destination": "/photos.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}